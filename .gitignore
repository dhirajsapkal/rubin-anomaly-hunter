# Project data (never commit science data).
# NB: we use `data/*` rather than `data/` so allowlist patterns below
# actually take effect — when a directory itself is ignored, git skips
# recursion into it and `!` rules are silently no-ops.
data/*
!data/.gitkeep
!data/README.md
runs/
archive/
*.sqlite
*.sqlite-journal
*.sqlite3
*.parquet
*.fits

# Exception: the synthetic demo DB is a committed fallback so Streamlit
# Cloud's cold-start has something to render when the orphan data branch
# hasn't been published yet (or the rehydrate secret is unset). It is
# mock data per scripts/make_demo_db.py and ADR-0009's verbatim-alert
# rule does NOT apply — no real alerts live here.
# This negation must come AFTER the `*.sqlite` global ignore above,
# otherwise that rule re-ignores it.
!data/demo.sqlite

# find_orb artifacts — ADR-0008 forbids redistribution
find_orb/
fo
fo.exe
*.DAT
ELP82.DAT
cometg.txt
bc405.cmt
linux_p1550p2650.440
sb441-n16.bsp

# Streamlit
.streamlit/secrets.toml

# Credentials
*.token
*.key
.env
.env.*
!.env.example

# Claude Code local settings (per-user; may contain approved Bash entries
# that embed secrets the operator passed on the command line)
.claude/settings.local.json
.claude/*.local.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

